{
  "name": "String Generator Bot",
  "description": "Telegram bot for generating Pyrogram & Telethon string sessions with force join and security features.",
  "repository": "https://github.com/yashcodex121/stringgenbot",
  "logo": "https://telegra.ph/file/0a1b2c3d4e5f6.png",
  "keywords": [
    "telegram",
    "bot",
    "pyrogram",
    "telethon",
    "string-session"
  ],
  "env": {
    "API_ID": {
      "description": "Get from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Get from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Get from BotFather",
      "required": true
    },
    "CHANNEL": {
      "description": "Force join channel username (without @)",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram user ID",
      "required": true
    },
    "MONGO_URL": {
      "description": "MongoDB Atlas connection string",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
